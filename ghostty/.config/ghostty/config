#Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.

#fonts
#font-family = Iosevka

#font-family = JetBrainsMono
#font-size = 13
#font-feature = zero, -calt, -liga, -dlig

font-family = "GohuFont 14 Nerd Font Mono"
font-size = 14

#font-family = "Terminess Nerd Font Mono"
#font-size = 14

#font-family = "DepartureMono Nerd Font"

#font-family = "OpenDyslexicM Nerd Font"
#font-size = 11

#styling
window-decoration = server
gtk-titlebar = true
#theme = "nord"
#theme = "Dark+"
theme = "Everforest Dark - Hard"
#cursor-color = a7c080
cursor-color = DDFFDD
background-opacity = 1
unfocused-split-opacity = 1

#shaders

custom-shader = shaders/cursor_smear.glsl
#custom-shader = shaders/cursor_blaze.glsl
#custom-shader = shaders/cursor_smear_fade.glsl
#custom-shader = shaders/bloom075.glsl

#keybinds

#keybind = ctrl+h=goto_split:left
#keybind = ctrl+j=goto_split:bottom
#keybind = ctrl+k=goto_split:top
#keybind = ctrl+l=goto_split:right

keybind = ctrl+a>h=new_split:left
keybind = ctrl+a>j=new_split:down
keybind = ctrl+a>k=new_split:up
keybind = ctrl+a>l=new_split:right
keybind = ctrl+a>f=toggle_split_zoom

keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab

#setting
window-save-state = always


